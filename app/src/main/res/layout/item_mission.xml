<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/card_background"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView android:id="@+id/tvMissionName" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvMissionType" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#CFD8DC" />
    <TextView android:id="@+id/tvDifficulty" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" />
    <TextView android:id="@+id/tvThreat" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" />
    <TextView android:id="@+id/tvRewards" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" />
    <TextView android:id="@+id/tvModifier" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#80DEEA" />
    <TextView android:id="@+id/tvEnemies" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" />
</LinearLayout>
