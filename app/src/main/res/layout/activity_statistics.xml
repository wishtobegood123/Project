<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0b132b">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:id="@+id/tvTotalMissions" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="18sp" />
        <TextView android:id="@+id/tvSuccessfulMissions" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="18sp" />
        <TextView android:id="@+id/tvSuccessRate" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="18sp" />
        <TextView android:id="@+id/tvTotalTraining" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="18sp" />
        <TextView android:id="@+id/tvTotalXp" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="18sp" />
        <TextView android:id="@+id/tvTotalFragments" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="18sp" />

        <com.example.spacecolonypioneers.ui.view.PieChartView
            android:id="@+id/pieChartMissions"
            android:layout_width="match_parent"
            android:layout_height="340dp"
            android:layout_marginTop="12dp" />

        <com.example.spacecolonypioneers.ui.view.BarChartView
            android:id="@+id/barChartDamage"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="12dp" />

        <com.example.spacecolonypioneers.ui.view.BarChartView
            android:id="@+id/barChartHealing"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="12dp" />

        <com.example.spacecolonypioneers.ui.view.BarChartView
            android:id="@+id/barChartMissionsPerCrew"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="12dp" />

        <Button android:id="@+id/btnBackFromStats" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Back" />
    </LinearLayout>
</ScrollView>
